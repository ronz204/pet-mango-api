model Room {
  id   Int    @id @default(autoincrement())
  name String @unique

  visibility RoomVisibility @default(PRIVATE)

  members Member[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rooms")
  @@schema("mango")
}

enum RoomVisibility {
  PUBLIC
  PRIVATE

  @@schema("mango")
}
